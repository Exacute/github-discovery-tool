# Database Configuration
DATABASE_URL=sqlite:///github_discovery.db

# Flask Configuration
FLASK_ENV=development
FLASK_PORT=5000

# Embeddings Provider Configuration
# Choose one: openai, ollama, local
# Default: openai (if not set, OpenAI will be used if available)
EMBEDDINGS_PROVIDER=openai

# OpenAI Configuration (if using OpenAI provider)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama Configuration (if using Ollama provider)
# Requires Ollama to be running locally
# Download from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# Local Embeddings Configuration (if using local provider)
# Model options: all-MiniLM-L6-v2, all-mpnet-base-v2, etc.
# See: https://www.sbert.net/docs/pretrained_models.html
LOCAL_EMBEDDINGS_MODEL=all-MiniLM-L6-v2
